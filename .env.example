# Copy to `.env` and fill in. Consumed by docker-compose.yml.
#
# Secrets do NOT live here — they are mounted as Docker secrets (files). Create:
#   secrets/sentry_token      one line: the Sentry auth token
#   secrets/aws_credentials   an AWS shared-credentials file, e.g.
#                               [default]
#                               aws_access_key_id = ...
#                               aws_secret_access_key = ...
# (If S3 auth comes from an instance role, drop the aws_credentials secret from
# docker-compose.yml instead.)

# --- S3 / symbol store (required) ---
S3_BUCKET=sentry-dsyms-prod
S3_REGION=us-east-1
# For S3-compatible backends (MinIO, Ceph). Leave empty for AWS S3.
S3_ENDPOINT_URL=
# Prefix prepended to derived blob keys, if your store is not at the bucket root.
S3_KEY_PREFIX=

# --- Sentry resolver ---
SENTRY_API_URL=https://sentry.internal/api/0
SENTRY_ORG=corp
SENTRY_PROJECT=client

# --- Daemon knobs (optional; defaults shown) ---
LOG_LEVEL=info
DEBUGINFOD=true
CACHE_MAX_UNUSED_FOR=336h
BIND_PORT=8080
ADMIN_PORT=9090

# Run a published image instead of the local ko build:
# DEBUGSYMD_IMAGE=registry.internal/debugsymd:latest
